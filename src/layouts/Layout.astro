---
import { siteConfig } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "pl";
}

const {
  title = `${siteConfig.personalBrand} — ${siteConfig.offerName}`,
  description = "Fractional delivery and requirements leadership for regulated and fintech teams.",
  lang = "en",
} = Astro.props;

const GA_ID = siteConfig.gaMeasurementId;
const hasAnalytics = typeof GA_ID === "string" && GA_ID.trim().length > 0;
const privacyHref = lang === "pl" ? "/pl/privacy/" : "/privacy/";

const consentCopy = lang === "pl"
  ? {
      text: "Używam Google Analytics, żeby sprawdzać, które treści i działania na stronie są użyteczne. Analityka działa dopiero po Twojej zgodzie.",
      accept: "Akceptuję analitykę",
      reject: "Nie teraz",
      privacy: "Prywatność",
    }
  : {
      text: "I use Google Analytics to understand which content and actions on the site are useful. Analytics runs only after your consent.",
      accept: "Accept analytics",
      reject: "Not now",
      privacy: "Privacy",
    };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>

  <body>
    <slot />

    {
      hasAnalytics && (
        <aside class="cookie-banner" data-cookie-banner hidden>
          <p>{consentCopy.text} <a href={privacyHref}>{consentCopy.privacy}</a></p>
          <div>
            <button type="button" data-analytics-accept>{consentCopy.accept}</button>
            <button type="button" data-analytics-reject>{consentCopy.reject}</button>
          </div>
        </aside>
      )
    }

    <script is:inline define:vars={{ GA_ID, hasAnalytics }}>
      const trackedSections = new Set();
      let analyticsLoaded = false;

      const getLanguage = () => {
        return document.documentElement.lang || (window.location.pathname.startsWith("/pl") ? "pl" : "en");
      };

      const loadAnalytics = () => {
        if (!hasAnalytics || analyticsLoaded || !GA_ID) return;
        analyticsLoaded = true;

        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = gtag;
        gtag("js", new Date());
        gtag("config", GA_ID, {
          page_path: window.location.pathname,
          language: getLanguage(),
        });

        const script = document.createElement("script");
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
        document.head.appendChild(script);
      };

      const sendAnalyticsEvent = (eventName, params = {}) => {
        if (typeof window.gtag !== "function") return;

        window.gtag("event", eventName, {
          language: getLanguage(),
          page_path: window.location.pathname,
          ...params,
        });
      };

      const consentValue = hasAnalytics ? window.localStorage.getItem("analytics_consent") : "rejected";
      const banner = document.querySelector("[data-cookie-banner]");

      if (consentValue === "accepted") {
        loadAnalytics();
      } else if (hasAnalytics && consentValue !== "rejected" && banner) {
        banner.hidden = false;
      }

      document.querySelector("[data-analytics-accept]")?.addEventListener("click", () => {
        window.localStorage.setItem("analytics_consent", "accepted");
        banner?.setAttribute("hidden", "");
        loadAnalytics();
        sendAnalyticsEvent("analytics_consent_update", { status: "accepted" });
      });

      document.querySelector("[data-analytics-reject]")?.addEventListener("click", () => {
        window.localStorage.setItem("analytics_consent", "rejected");
        banner?.setAttribute("hidden", "");
      });

      if ("IntersectionObserver" in window) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const section = entry.target;
              const sectionId = section.id;
              if (!sectionId) return;

              const uniqueKey = `${window.location.pathname}#${sectionId}`;
              if (trackedSections.has(uniqueKey)) return;

              trackedSections.add(uniqueKey);

              sendAnalyticsEvent("section_view", {
                section_id: sectionId,
                section_name: section.dataset.sectionName || sectionId,
              });

              if (sectionId === "hero") sendAnalyticsEvent("view_hero");
              if (sectionId === "pricing") sendAnalyticsEvent("view_pricing");
              if (sectionId === "faq") sendAnalyticsEvent("view_faq");
            });
          },
          { threshold: 0.5 }
        );

        document.querySelectorAll("section[id]").forEach((section) => {
          sectionObserver.observe(section);
        });
      }

      document.querySelectorAll("[data-ga-event]").forEach((element) => {
        element.addEventListener("click", () => {
          const eventName = element.dataset.gaEvent;
          if (!eventName) return;

          const payload = {};
          if (element.dataset.gaLocation) payload.location = element.dataset.gaLocation;
          if (element.dataset.gaTier) payload.tier = element.dataset.gaTier;
          if (element.dataset.gaProduct) payload.product = element.dataset.gaProduct;
          if (element.dataset.gaLabel) payload.label = element.dataset.gaLabel;

          sendAnalyticsEvent(eventName, payload);

          if (eventName === "select_product" && element.dataset.gaProduct === "readiness_review") {
            sendAnalyticsEvent("readiness_review_start", {
              product: "readiness_review",
              location: element.dataset.gaLocation || "product_card",
            });
          }
        });
      });

      document.querySelectorAll("details").forEach((details) => {
        details.addEventListener("toggle", () => {
          if (!details.open) return;
          const summary = details.querySelector("summary");
          sendAnalyticsEvent("faq_open", {
            q: summary ? summary.textContent.trim() : "unknown",
          });
        });
      });
    </script>
  </body>
</html>
