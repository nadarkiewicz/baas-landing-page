---
import "../styles/global.css";
import { siteConfig } from "../config/site";

const {
  title = "BAaaS",
  description = "Fractional delivery leadership for regulated and fintech teams.",
  lang = "en",
} = Astro.props;

const GA_ID = siteConfig.gaMeasurementId;
const hasAnalytics = typeof GA_ID === "string" && GA_ID.trim().length > 0;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    {
      hasAnalytics && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
          <script is:inline define:vars={{ GA_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              window.dataLayer.push(arguments);
            }
            window.gtag = gtag;
            gtag("js", new Date());
            gtag("config", GA_ID);
          </script>
        </>
      )
    }
  </head>

  <body>
    <slot />

    <script is:inline>
      const trackedSections = new Set();
      const trackedFaqs = new Set();

      const getLanguage = () => {
        const htmlLang = document.documentElement.lang;
        if (htmlLang) return htmlLang;
        if (window.location.pathname.startsWith("/pl")) return "pl";
        return "en";
      };

      const sendAnalyticsEvent = (eventName, params = {}) => {
        if (typeof window.gtag !== "function") return;
        window.gtag("event", eventName, {
          language: getLanguage(),
          page_path: window.location.pathname,
          ...params,
        });
      };

      const sectionEventMap = {
        hero: "view_hero",
        problem: "scroll_problem",
        "two-ways": "scroll_two_ways",
        products: "view_products",
        "how-it-works": "scroll_how",
        pricing: "view_pricing",
        included: "view_included",
        proof: "scroll_proof",
        faq: "view_faq",
        "lead-magnet": "view_lead_magnet",
        contact: "view_contact",
      };

      if ("IntersectionObserver" in window) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const section = entry.target;
              const sectionId = section.id;
              if (!sectionId) return;

              const uniqueKey = `${window.location.pathname}#${sectionId}`;
              if (trackedSections.has(uniqueKey)) return;

              trackedSections.add(uniqueKey);

              const baseParams = {
                section_id: sectionId,
                section_name: section.dataset.sectionName || sectionId,
              };

              sendAnalyticsEvent("section_view", baseParams);

              if (sectionEventMap[sectionId]) {
                sendAnalyticsEvent(sectionEventMap[sectionId], baseParams);
              }
            });
          },
          { threshold: 0.45 }
        );

        document.querySelectorAll("section[id]").forEach((section) => {
          sectionObserver.observe(section);
        });
      }

      document.querySelectorAll("[data-analytics-click], [data-ga-event]").forEach((element) => {
        element.addEventListener("click", () => {
          const eventName = element.dataset.gaEvent || "cta_click";
          const params = {};

          if (element.dataset.analyticsClick) params.cta_name = element.dataset.analyticsClick;
          if (element.dataset.gaLocation) params.location = element.dataset.gaLocation;
          if (element.dataset.gaProduct) params.product = element.dataset.gaProduct;
          if (element.dataset.gaTier) params.tier = element.dataset.gaTier;

          sendAnalyticsEvent(eventName, params);

          if (eventName === "select_product" && element.dataset.gaProduct === "readiness_review") {
            sendAnalyticsEvent("readiness_review_start", params);
          }
        });
      });

      document.querySelectorAll("details").forEach((details, index) => {
        details.addEventListener("toggle", () => {
          if (!details.open) return;

          const summary = details.querySelector("summary");
          const question = summary ? summary.textContent.trim() : `faq_${index + 1}`;
          const key = `${window.location.pathname}:${question}`;
          if (trackedFaqs.has(key)) return;

          trackedFaqs.add(key);
          sendAnalyticsEvent("faq_open", { q: question });
        });
      });
    </script>
  </body>
</html>
