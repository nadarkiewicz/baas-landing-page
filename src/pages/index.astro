---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/site";
import Button from "../components/Button.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import ProductCard from "../components/ProductCard.astro";
import PricingCard from "../components/PricingCard.astro";
import ProofCard from "../components/ProofCard.astro";
import FaqItem from "../components/FaqItem.astro";
import LeadMagnet from "../components/LeadMagnet.astro";

const { contactEmail, bookingLink, readinessReviewLink, leadMagnetAction } = siteConfig;
---

<Layout
  title="BAaaS — Fractional delivery leadership for regulated and fintech teams"
  description="Senior requirements, decisions and documentation — retained monthly, or as fixed-scope projects."
  lang="en"
>
  <main>
    <LanguageSwitch current="en" />

    <div class="sticky-cta">
      <div class="sticky-cta-inner">
        <span class="sticky-title">BAaaS · Fractional delivery leadership</span>
        <Button
          href={bookingLink}
          variant="primary"
          analyticsClick="book_call_sticky_en"
          gaEvent="cta_book_click"
          gaLocation="sticky"
        >
          Book a 30-minute call
        </Button>
      </div>
    </div>

    <section id="hero" data-section-name="Hero" class="section hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">BAaaS</p>
          <h1>Fractional delivery leadership for regulated and fintech teams.</h1>
          <p class="hero-lead">
            Senior requirements, decisions and documentation — retained monthly,
            or as fixed-scope projects. 17+ years in banking, regulated finance
            and complex software, without a full-time hire.
          </p>

          <div class="actions">
            <Button
              href={bookingLink}
              variant="primary"
              analyticsClick="book_call_hero_en"
              gaEvent="cta_book_click"
              gaLocation="hero"
            >
              Book a 30-minute call
            </Button>

            <Button
              href={readinessReviewLink}
              variant="secondary"
              analyticsClick="readiness_review_hero_en"
              gaEvent="readiness_review_start"
              gaProduct="readiness_review"
              gaLocation="hero"
            >
              Start with a Readiness Review →
            </Button>
          </div>

          <p class="trust-strip">
            17+ years · Banking · Fintech · Regulated software · DORA / KYC-AML
          </p>
        </div>

        <aside class="hero-card" aria-label="BAaaS summary">
          <p class="card-label">Senior help upstream of the build</p>
          <ul>
            <li>Requirements, decisions and documentation</li>
            <li>Fixed-scope products or monthly retained access</li>
            <li>Built for regulated, fintech and complex-software teams</li>
            <li>Clear outputs, fixed entry points, measurable intent</li>
          </ul>
        </aside>
      </div>
    </section>

    <section id="problem" data-section-name="The problem" class="section">
      <div class="container two-column">
        <div>
          <p class="eyebrow">The problem</p>
          <h2>The gap usually sits upstream of the build.</h2>
        </div>

        <div class="content-stack">
          <p>
            When delivery slips, decisions stall, or your documentation wouldn't
            survive an audit, the cause is usually <strong>upstream of the build</strong> —
            no one senior owns the requirements and the decisions.
          </p>

          <p>
            <strong>If you run delivery, product or a transformation:</strong>
            capable people handle requirements and stakeholders in the gaps, but
            no senior owns the thread. Decisions wait. Rework piles up.
            Audit-readiness slips.
          </p>

          <p>
            <strong>If you carry capability or regulatory pressure:</strong> you
            need senior rigour your team keeps — not a generic training day, and
            not a slow, expensive full-time hire you only half-need.
          </p>
        </div>
      </div>
    </section>

    <section id="two-ways" data-section-name="Two ways to work" class="section muted">
      <div class="container">
        <p class="eyebrow">Two ways to work</p>
        <h2>Start with a project, or retain senior capacity monthly.</h2>

        <div class="steps">
          <article>
            <span>1</span>
            <h3>Start with a fixed-scope project.</h3>
            <p>
              A named piece of work, fixed price, clear deliverable. The
              simplest way to get value fast and see how we work.
            </p>
          </article>

          <article>
            <span>2</span>
            <h3>Retain senior capacity monthly.</h3>
            <p>
              Ongoing access for requirements, decisions and documentation
              across your work — about three senior days a month, used where the
              gap is.
            </p>
          </article>

          <article>
            <span>3</span>
            <h3>Move when it is paying off.</h3>
            <p>
              Most clients start with a project and move to retained once it is
              paying off.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="products" data-section-name="Fixed-scope products" class="section">
      <div class="container">
        <p class="eyebrow">Fixed-scope products</p>
        <h2>Fixed scope, fixed price, senior delivery.</h2>
        <p>
          Buy one on its own — or use it inside a retained month.
        </p>

        <div class="product-grid">
          <ProductCard
            title="Delivery Readiness Review"
            price="£1,950"
            productKey="readiness_review"
            ctaHref={readinessReviewLink}
            ctaText="Start here"
            badge="Best first step"
            featured
            lang="en"
          >
            A senior look at where your requirements, decisions and delivery are
            quietly costing you, with a prioritised plan to fix it. Credited to
            your first month if you go retained within 30 days.
          </ProductCard>

          <ProductCard
            title="Regulation into Requirements"
            price="from £5,850"
            productKey="regulation_requirements"
            ctaHref={bookingLink}
            ctaText="Discuss this"
            lang="en"
          >
            Turn a regulation — DORA, KYC/AML, a new rule from your regulator —
            into clear business rules and a team-by-team list of what changes.
            The complex made usable.
          </ProductCard>

          <ProductCard
            title="Requirements Reset"
            price="from £3,900"
            productKey="requirements_reset"
            ctaHref={bookingLink}
            ctaText="Discuss this"
            lang="en"
          >
            Get clear, testable requirements and a shared definition of ready,
            so your team stops re-arguing the same things and rebuilding work twice.
          </ProductCard>

          <ProductCard
            title="Decision Paper"
            price="from £1,950"
            productKey="decision_paper"
            ctaHref={bookingLink}
            ctaText="Discuss this"
            lang="en"
          >
            Take one decision that has been stuck for weeks to clear options,
            honest trade-offs, and a recommendation your team can actually act on.
          </ProductCard>
        </div>

        <div class="actions">
          <Button
            href={bookingLink}
            variant="primary"
            analyticsClick="book_call_products_en"
            gaEvent="cta_book_click"
            gaLocation="products"
          >
            See which fits → Book a 30-minute call
          </Button>
        </div>
      </div>
    </section>

    <section id="how-it-works" data-section-name="Retained monthly" class="section dark">
      <div class="container">
        <p class="eyebrow">Or retain senior capacity monthly</p>
        <h2>For ongoing need, hold senior capacity each month.</h2>
        <p>
          The subscription holds senior capacity for you each month — used
          flexibly where it helps most.
        </p>

        <div class="steps">
          <article>
            <span>1</span>
            <h3>Pick a tier.</h3>
            <p>Core, Pro or Prime — same service, three levels of priority and scope.</p>
          </article>

          <article>
            <span>2</span>
            <h3>Agree the month’s mix.</h3>
            <p>
              Within ~3 senior days: a document, a workshop, on-call advisory,
              decision support.
            </p>
          </article>

          <article>
            <span>3</span>
            <h3>Keep everything.</h3>
            <p>Documents, templates and methods stay inside your company.</p>
          </article>
        </div>

        <p class="wide-note">
          You are paying for retained access and priority, not hours. Capacity
          is deliberately limited, so quality stays high. Unused time does not
          roll over; we hold the capacity for you.
        </p>
      </div>
    </section>

    <section id="pricing" data-section-name="Pricing" class="section dark">
      <div class="container">
        <p class="eyebrow">Pricing</p>
        <h2>Monthly retained access for requirements, decisions and documentation.</h2>

        <div class="pricing-grid">
          <PricingCard
            tier="Core"
            price="from £5,850 / month + VAT"
            description="Structured retained access where the need is clear and the delivery can be more asynchronous."
            ctaHref={bookingLink}
            ctaText="Discuss Core"
            lang="en"
          />

          <PricingCard
            tier="Pro"
            price="from £7,200 / month + VAT"
            description="A practical balance of access, responsiveness and tailored support for ongoing delivery pressure."
            badge="Most chosen"
            featured
            ctaHref={bookingLink}
            ctaText="Discuss Pro"
            lang="en"
          />

          <PricingCard
            tier="Prime"
            price="from £9,500 / month + VAT"
            description="Higher priority, closer involvement and more tailored support. Or scoped to your needs."
            ctaHref={bookingLink}
            ctaText="Discuss Prime"
            lang="en"
          />
        </div>

        <p class="pricing-note">
          Monthly rolling, or annual with a commitment discount.
          <strong> Monthly rolling — no long lock-in. Start with a month and see.</strong>
        </p>

        <div class="actions">
          <Button
            href={bookingLink}
            variant="light"
            analyticsClick="book_call_pricing_en"
            gaEvent="cta_book_click"
            gaLocation="pricing"
          >
            Book a 30-minute call
          </Button>
        </div>
      </div>
    </section>

    <section id="included" data-section-name="What the subscription includes" class="section muted">
      <div class="container two-column">
        <div>
          <p class="eyebrow">What the subscription includes</p>
          <h2>Clear monthly support, with clear boundaries.</h2>
        </div>

        <div class="list-card">
          <ul class="check-list">
            <li>One analytical or management document each month, on an agreed day.</li>
            <li>On-call availability during business hours — roughly two days a week.</li>
            <li>Ad hoc and longer sessions within the response times for your tier.</li>
            <li>Workshops, facilitation, decision support, templates and follow-up.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="not-included" data-section-name="What it doesn't" class="section">
      <div class="container two-column">
        <div>
          <p class="eyebrow">What it doesn’t</p>
          <h2>No hidden promise of unlimited availability.</h2>
        </div>

        <div class="list-card">
          <ul class="plain-list">
            <li>Unlimited support or a guaranteed instant turnaround.</li>
            <li>Rollover of unused time.</li>
            <li>Large multi-week programmes. These are priced separately.</li>
            <li>Travel and on-site work. Prime may include a quarterly on-site visit; you cover travel.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="proof" data-section-name="Who's behind it" class="section">
      <div class="container two-column">
        <div>
          <p class="eyebrow">Who’s behind it</p>
          <h2>One senior/principal-level practitioner.</h2>
          <p>
            MBA. 17+ years, including 4+ in banking and regulated finance.
            Comfortable where documentation quality, audit trails and decision
            traceability matter. Clients kept anonymous by default.
          </p>
        </div>

        <div class="proof-list">
          <ProofCard title="DORA business rules">
            Translated the DORA regulation into business rules used by 35–50
            product owners across a tier-1 bank.
          </ProofCard>

          <ProofCard title="Regulated telecom platform under M&A">
            Principal lead work cut sprint spillover of nearly-done work from
            10–20% to near zero, and roughly halved late rework.
          </ProofCard>

          <ProofCard title="Multi-team KYC/AML programme">
            Coordinated requirements across onboarding, AML monitoring,
            sanctions/PEP screening and regulatory reporting.
          </ProofCard>

          <ProofCard title="Omnichannel customer-value model">
            Built an omnichannel customer-value model for a large retailer and
            presented it at an IAB meeting.
          </ProofCard>
        </div>
      </div>
    </section>

    <section id="faq" data-section-name="Questions" class="section muted">
      <div class="container">
        <p class="eyebrow">Questions</p>
        <h2>Common questions before a call or first project.</h2>

        <div class="faq-list">
          <FaqItem question="Do I have to commit to a subscription?">
            No. Start with a fixed-scope project — the Readiness Review is the
            usual first step — and move to retained only if it makes sense.
          </FaqItem>

          <FaqItem question="Is the subscription just three days a month at a day rate?">
            No. It is retained access — priority, availability and senior
            delivery across the month. The value is reliable senior capacity on
            demand, not a discounted day rate.
          </FaqItem>

          <FaqItem question="What if we do not use the time one month?">
            It does not roll over. You are holding senior capacity ready for when you need it.
          </FaqItem>

          <FaqItem question="Can you work in our hours?">
            Polish working hours overlap almost the entire UK and European
            business day — real-time when you want it, asynchronous when that suits.
          </FaqItem>

          <FaqItem question="Can you handle regulated or sensitive work?">
            Yes — banking, KYC/AML, audit-trail design and operational-resilience
            regulation. NDA as standard; clients kept anonymous.
          </FaqItem>
        </div>
      </div>
    </section>

    <LeadMagnet lang="en" contactEmail={contactEmail} action={leadMagnetAction} />

    <section id="contact" data-section-name="Ready?" class="section final-cta">
      <div class="container">
        <p class="eyebrow">Ready?</p>
        <h2>A 30-minute call, or a fixed-scope Readiness Review — whichever fits.</h2>
        <p>
          Either way, you will get an honest read on where the gap is.
        </p>

        <div class="actions">
          <Button
            href={bookingLink}
            variant="primary"
            analyticsClick="book_call_footer_en"
            gaEvent="cta_book_click"
            gaLocation="footer"
          >
            Book a 30-minute call
          </Button>

          <Button
            href={readinessReviewLink}
            variant="secondary"
            analyticsClick="readiness_review_footer_en"
            gaEvent="readiness_review_start"
            gaProduct="readiness_review"
            gaLocation="footer"
          >
            Start with a Readiness Review
          </Button>

          <Button
            href={`mailto:${contactEmail}`}
            variant="ghost"
            analyticsClick="email_footer_en"
            gaEvent="outbound_click"
            gaLocation="footer"
          >
            Email {contactEmail}
          </Button>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container footer-inner">
        <p>BAaaS · NDA as standard · Clients kept anonymous by default</p>
        <a href={`mailto:${contactEmail}`} data-ga-event="outbound_click" data-analytics-click="email_footer_link_en">
          {contactEmail}
        </a>
      </div>
    </footer>
  </main>
</Layout>
