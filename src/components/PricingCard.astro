---
import Button from "./Button.astro";

interface Props {
  tier: "Core" | "Pro" | "Prime";
  price: string;
  badge?: string;
  featured?: boolean;
  ctaHref: string;
  ctaText: string;
  language: "en" | "pl";
}

const {
  tier,
  price,
  badge,
  featured = false,
  ctaHref,
  ctaText,
  language,
} = Astro.props;

const tierKey = tier.toLowerCase();
const classes = ["tier", featured ? "featured" : ""].filter(Boolean).join(" ");
---

<article class={classes}>
  {badge && <p class="badge">{badge}</p>}
  <h3>{tier}</h3>
  <p class="price">{price}</p>

  <Button
    href={ctaHref}
    variant={featured ? "primary" : "secondary"}
    gaEvent="select_tier"
    gaTier={tierKey}
    gaLocation={`pricing_${language}`}
    class="card-cta"
  >
    {ctaText}
  </Button>
</article>
