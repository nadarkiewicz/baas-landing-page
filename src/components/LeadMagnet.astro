---
import Button from "./Button.astro";

type Language = "en" | "pl";

interface Props {
  lang: Language;
  guideLink: string;
  bookingLink: string;
}

const { lang, guideLink, bookingLink } = Astro.props;

const copy = {
  en: {
    eyebrow: "Not ready to talk?",
    title: "Take the thinking with you.",
    body: "Get the guide — The hidden cost of unclear requirements — plus a one-page Definition of Ready checklist.",
    guideCta: "Get the guide",
    bookCta: "Book a call instead",
    note: "Low-friction fallback. You will be asked only for your email and consent.",
    gaLocation: "lead_magnet_en",
  },
  pl: {
    eyebrow: "Nie na teraz?",
    title: "Zabierz to ze sobą.",
    body: "Pobierz przewodnik o ukrytym koszcie niejasnych wymagań oraz jednostronicową listę kontrolną Definition of Ready.",
    guideCta: "Pobierz przewodnik",
    bookCta: "Umów rozmowę zamiast tego",
    note: "Niski próg wejścia. W formularzu proszę tylko o adres e-mail i zgodę.",
    gaLocation: "lead_magnet_pl",
  },
}[lang];
---

<section id="lead-magnet" data-section-name={copy.title} class="section lead-magnet-section">
  <div class="container lead-magnet">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2>{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="lead-actions" aria-label={copy.title}>
      <Button
        href={guideLink}
        variant="primary"
        target="_blank"
        rel="noopener noreferrer"
        gaEvent="lead_magnet_start"
        gaLocation={copy.gaLocation}
        gaLabel="guide"
      >
        {copy.guideCta}
      </Button>
      <Button href={bookingLink} variant="secondary" gaEvent="cta_book_click" gaLocation={copy.gaLocation}>
        {copy.bookCta}
      </Button>
      <p class="form-note">{copy.note}</p>
    </div>
  </div>
</section>
