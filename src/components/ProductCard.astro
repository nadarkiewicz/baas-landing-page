---
import Button from "./Button.astro";

interface Props {
  title: string;
  price: string;
  description: string;
  productKey: string;
  ctaHref: string;
  ctaText: string;
  featured?: boolean;
  badge?: string;
  language: "en" | "pl";
}

const {
  title,
  price,
  description,
  productKey,
  ctaHref,
  ctaText,
  featured = false,
  badge,
  language,
} = Astro.props;

const classes = ["product-card", featured ? "featured" : ""].filter(Boolean).join(" ");
---

<article class={classes}>
  {badge && <p class="badge">{badge}</p>}
  <h3>{title}</h3>
  <p class="product-price">{price}</p>
  <p>{description}</p>

  <Button
    href={ctaHref}
    variant={featured ? "primary" : "secondary"}
    gaEvent="select_product"
    gaProduct={productKey}
    gaLocation={`product_${language}`}
    class="card-cta"
  >
    {ctaText}
  </Button>
</article>
