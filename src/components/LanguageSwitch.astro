---
type Language = "en" | "pl";

interface Props {
  current: Language;
}

const { current } = Astro.props;
---

<nav class="language-switch" aria-label={current === "pl" ? "Przełącznik języka" : "Language switcher"}>
  <a
    href="/"
    aria-current={current === "en" ? "page" : undefined}
    data-ga-event="language_switch"
    data-ga-label="en"
  >
    EN
  </a>

  <a
    href="/pl/"
    aria-current={current === "pl" ? "page" : undefined}
    data-ga-event="language_switch"
    data-ga-label="pl"
  >
    PL
  </a>
</nav>
