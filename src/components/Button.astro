---
type Variant = "primary" | "secondary" | "light" | "text";

interface Props {
  href: string;
  variant?: Variant;
  gaEvent?: string;
  gaLocation?: string;
  gaProduct?: string;
  gaTier?: string;
  gaLabel?: string;
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  gaEvent,
  gaLocation,
  gaProduct,
  gaTier,
  gaLabel,
  target,
  rel,
  class: className = "",
} = Astro.props;

const classes = ["button", variant, className].filter(Boolean).join(" ");
---

<a
  class={classes}
  href={href}
  target={target}
  rel={rel}
  data-ga-event={gaEvent}
  data-ga-location={gaLocation}
  data-ga-product={gaProduct}
  data-ga-tier={gaTier}
  data-ga-label={gaLabel}
>
  <slot />
</a>
